{
  "name": "whatsapp-wrapper",
  "version": "1.0.0",
  "description": "A native WhatsApp desktop wrapper for Linux — built on Electron",
  "main": "main.js",
  "type": "module",
  "author": "Adam",
  "license": "MIT",
  "scripts": {
    "start": "electron .",
    "dev": "electron . --dev",
    "dist": "electron-builder",
    "dist:appimage": "electron-builder --linux AppImage",
    "dist:deb": "electron-builder --linux deb"
  },
  "dependencies": {
    "electron-store": "11.0.2"
  },
  "devDependencies": {
    "electron": "43.0.0",
    "electron-builder": "26.15.6"
  },
  "allowScripts": {
    "electron-winstaller@5.4.0": true
  }
}
